rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Recipe Validation
    function isValidRecipe(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.description is string && data.description.size() < 2000 &&
             data.image is string && data.image.size() < 1000 &&
             data.time is string &&
             data.calories is number &&
             data.category is string &&
             data.difficulty is string &&
             data.ingredients is list &&
             data.instructions is list;
    }

    // User Validation
    function isValidUser(data) {
      return data.email is string &&
             data.plannerUseCount is number && data.plannerUseCount >= 0 &&
             data.isSubscribed is bool;
    }

    // Collections
    match /recipes/{recipeId} {
      allow read: if true;
      allow create: if isAdmin() && isValidRecipe(incoming());
      allow update: if isAdmin() && isValidRecipe(incoming());
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                      incoming().plannerUseCount == 0 &&
                      incoming().isSubscribed == false &&
                      (!incoming().keys().hasAll(['isAdmin']) || incoming().isAdmin == false);
      allow update: if (isOwner(userId) && isValidUser(incoming()) &&
                      incoming().email == existing().email &&
                      incoming().isAdmin == existing().isAdmin &&
                      incoming().isSubscribed == existing().isSubscribed) ||
                      isAdmin();
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false; 
    }
  }
}
